---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const projects = [
  {
    title: 'From Brand to Browser: Dubai NLI Design',
    slug: 'From Brand to Browser: Dubai NLI Design',
    meta: '2025 – Design System',
    previewSrc: '/previews/project-one.mp4',
    previewAlt: 'Preview for Project One',
  },
  {
    title: 'CMU and NUS Branding and Marketing',
    slug: 'project-two',
    meta: '2023 – Brand and Marketing',
    previewSrc: '/previews/project-two.mp4',
    previewAlt: 'Preview for Project Two',
  },
  {
    title: '3D Design',
    slug: 'project-three',
    meta: '2022 – Visual design',
    previewSrc: '/previews/720x480_demoreel_homepage.mp4',
    previewAlt: 'Preview for Project Three',
  },
  {
    title: 'QBP and Motex Website Ebay and Brand Design',
    slug: 'project-four',
    meta: '2021 – Visual and Website design',
    previewSrc: '/previews/project-four.mp4',
    previewAlt: 'Preview for Project Four',
  },
  {
    title: 'Golf Canada',
    slug: 'project-five',
    meta: '2020 – Visual and interaction design',
    previewSrc: '/previews/project-five.mp4',
    previewAlt: 'Preview for Project Five',
  },
  {
    title: 'T&T Supermarket',
    slug: 'project-six',
    meta: '2018 – Visual and UI design',
    previewSrc: '/previews/project-six.mp4',
    previewAlt: 'Preview for Project Six',
  },
] as const;
---

<BaseLayout title="Interactive Media Designer – Toronto" showNav={false}>
  <div class="min-h-screen">
    <section class="w-full max-w-xl mx-auto px-6 pb-24">
      <SiteHeader />

      <!-- w-fit so preview left-full ml-8 is exactly 32px from list right edge -->
      <div class="relative w-fit max-w-full">
        <!-- Projects list (pill/button style) -->
        <section aria-label="Selected work" class="mt-10 space-y-3" id="projects">
          {projects.map((p) => (
            <div class="block">
              <a
                href={`/projects/${p.slug}`}
                class="group inline-flex max-w-full
                       px-[1.35rem] py-[0.55em]
                       rounded-[0.4em]
                       bg-[#f8f7f1]
                       border border-[#f8f7f1]
                       text-[14px] text-[#1b222b]
                       cursor-pointer
                       shadow-[5px_5px_10px_rgba(0,0,0,0.06),-5px_-5px_10px_#ffffff]
                       transition-all duration-300
                       hover:text-[#666666]
                       hover:shadow-[inset_3px_3px_10px_rgba(0,0,0,0.06),inset_-3px_-3px_10px_#ffffff]
                       focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400"
                data-preview-src={p.previewSrc}
                data-preview-alt={p.previewAlt}
              >
                <div class="flex flex-col leading-snug text-left">
                  <span class="text-sm font-medium text-[#1b222b] font-title">{p.title}</span>
                  <span class="mt-0.5 text-xs text-[#1b222b]/80 font-body">{p.meta}</span>
                </div>
              </a>
            </div>
          ))}
        </section>

        <!-- Desktop hover preview: right of list, exactly 32px gap (ml-8) -->
        <div
          id="hover-preview"
          class="hidden lg:block absolute top-0 left-full ml-8 opacity-0 scale-95 pointer-events-none transition duration-150 max-h-[calc(100vh-3rem)]"
          style="max-width: min(420px, calc(100vw - var(--preview-left, 0px) - 24px));"
          aria-hidden="true"
        >
          <div id="hover-preview-inner" class="rounded-2xl border border-gray-200 bg-white overflow-hidden shadow-sm w-full h-full">
            <video
              id="project-preview-video"
              class="block w-full h-full object-contain"
              muted
              loop
              playsinline
              preload="metadata"
            />
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const previewWrap = document.getElementById('hover-preview');
  const previewInner = document.getElementById('hover-preview-inner');
  const previewVideo = document.getElementById('project-preview-video');
  const list = document.getElementById('projects');

  const getMaxHeight = () => (typeof window !== 'undefined' ? window.innerHeight - 48 : 600);

  function sizePreviewToVideo() {
    const v = previewVideo;
    const w = v.videoWidth;
    const h = v.videoHeight;
    if (!w || !h || !previewInner) return;
    // Preview starts at listWrap.right + 32px; leave 24px viewport padding on right
    const listWrap = list.parentElement;
    const listRight = listWrap ? listWrap.getBoundingClientRect().right : 0;
    const availableW = Math.max(120, window.innerWidth - listRight - 32 - 24);
    const maxW = Math.min(480, availableW);
    const maxH = getMaxHeight();
    const aspect = w / h;
    // Largest size that fits maxW/maxH and keeps video aspect ratio
    const width = Math.min(maxW, maxH * aspect);
    const height = width / aspect;
    previewInner.style.width = `${Math.round(width)}px`;
    previewInner.style.height = `${Math.round(height)}px`;
  }

  if (previewWrap && previewInner && previewVideo && list) {
    const links = list.querySelectorAll('a[data-preview-src]');

    const show = () => {
      previewWrap.classList.remove('opacity-0', 'scale-95');
      previewWrap.classList.add('opacity-100', 'scale-100');
    };

    const hide = () => {
      previewWrap.classList.add('opacity-0', 'scale-95');
      previewWrap.classList.remove('opacity-100', 'scale-100');
      previewVideo.src = '';
      previewVideo.pause();
      previewInner.removeAttribute('style');
    };

    const setPreviewFrom = (el) => {
      const src = el.getAttribute('data-preview-src');
      if (!src) return;
      previewVideo.src = src;
      previewVideo.load();
      previewVideo.onloadedmetadata = () => {
        sizePreviewToVideo();
        show();
      };
      // If metadata already cached, size immediately
      if (previewVideo.readyState >= 1) {
        sizePreviewToVideo();
        show();
      }
      previewVideo.play().catch(() => {});
    };

    links.forEach((el) => {
      el.addEventListener('mouseenter', () => setPreviewFrom(el));
      el.addEventListener('focus', () => setPreviewFrom(el));
    });

    list.addEventListener('mouseleave', hide);
    list.addEventListener('focusout', (e) => {
      if (!list.contains(e.relatedTarget)) hide();
    });
  }
</script>
